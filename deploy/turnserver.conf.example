# deploy/turnserver.conf.example — contoh config coturn (TURN server) untuk
# fitur Live Streaming FASOP. WAJIB ada supaya HP teknisi di lapangan (di
# belakang CGNAT operator seluler) bisa connect WebRTC.
#
# Install:
#   sudo apt update && sudo apt install -y coturn
#   sudo cp deploy/turnserver.conf.example /etc/turnserver.conf
#   sudo nano /etc/turnserver.conf   # isi realm, password, external-ip (kalau perlu)
#   sudo nano /etc/default/coturn    # pastikan baris TURNSERVER_ENABLED=1 (uncomment)
#   sudo systemctl enable --now coturn
#   sudo systemctl status coturn
#
# Setelah jalan, isi kredensial yang SAMA PERSIS di 2 tempat lain:
#   - .env Django              -> WEBRTC_ICE_SERVERS
#   - deploy/mediamtx.generated.yml -> webrtcICEServers2 (password:)
#
# Firewall: buka UDP 3478 (signaling TURN) + range UDP min-port..max-port
# di bawah (relay media) — tanpa ini TURN tidak bisa dipakai dari luar.

listening-port=3478

# WAJIB ganti — realm bebas asal konsisten, password harus KUAT & RAHASIA.
realm=fasop.internal
user=fasop:GANTI-PASSWORD-TURN-YANG-SAMA-DENGAN-MEDIAMTX-DAN-ENV-DJANGO

# Long-term credential mechanism (username/password statis, cocok untuk
# skala kecil FASOP — tidak perlu integrasi REST API/secret rotation).
lt-cred-mech
fingerprint

# Server ini di belakang NAT (kantor/on-premise, tidak punya IP publik
# langsung di NIC-nya) -> WAJIB isi, format PUBLIK/PRIVAT:
#
# JANGAN ambil IP publik dari `curl ifconfig.me` kalau firewall kantor
# pakai SD-WAN multi-WAN-link (mis. FortiGate dengan beberapa virtual WAN
# link) — ifconfig.me bisa kasih IP BEDA tiap kali dipanggil (SD-WAN pilih
# link keluar berbeda-beda per koneksi), bukan IP yang benar-benar dipakai
# untuk trafik MASUK. IP yang benar = IP di WAN interface spesifik yang
# di-dedikasikan buat Virtual IP/DNAT ke server ini (cek di FortiGate:
# Network > Interfaces, WAN yang dipasangi VIP untuk UDP 3478 & range di
# bawah, BUKAN SD-WAN zone gabungan).
external-ip=GANTI-IP-PUBLIK/GANTI-IP-PRIVAT-SERVER-INI

# Range port UDP untuk relay media — dipersempit (100 port, bukan default
# 49152-65535) supaya permintaan port forwarding ke tim jaringan lebih kecil
# dan gampang di-approve. 100 port cukup untuk beberapa sesi live bersamaan.
# Firewall/tim jaringan: buka UDP 3478 + range ini ke IP privat server ini.
min-port=49152
max-port=49251

# ── Hardening — WAJIB, jangan dihapus ──────────────────────────────────
# Cegah TURN server ini disalahgunakan jadi proxy ke jaringan internal PLN
# (SSRF) — TURN relay publik tanpa ini bisa dipakai orang luar buat akses
# IP privat/internal lewat server ini. MediaMTX yang di-relay ke sini ADA
# di jaringan privat juga (server yang sama) — makanya ditambah pengecualian
# eksplisit lewat allowed-peer-ip di bawah, WAJIB diisi sebelum enable.
allowed-peer-ip=GANTI-IP-PRIVAT-SERVER-INI   # sama dengan bagian kedua external-ip di atas — izin khusus MediaMTX di server ini, JANGAN buka seluruh subnet
denied-peer-ip=0.0.0.0-0.255.255.255
denied-peer-ip=10.0.0.0-10.255.255.255
denied-peer-ip=100.64.0.0-100.127.255.255
denied-peer-ip=127.0.0.0-127.255.255.255
denied-peer-ip=169.254.0.0-169.254.255.255
denied-peer-ip=172.16.0.0-172.31.255.255
denied-peer-ip=192.0.0.0-192.0.0.255
denied-peer-ip=192.0.2.0-192.0.2.255
denied-peer-ip=192.88.99.0-192.88.99.255
denied-peer-ip=192.168.0.0-192.168.255.255
denied-peer-ip=198.18.0.0-198.19.255.255
denied-peer-ip=198.51.100.0-198.51.100.255
denied-peer-ip=203.0.113.0-203.0.113.255
denied-peer-ip=240.0.0.0-255.255.255.255

# Matikan CLI admin telnet (tidak dipakai FASOP, kurangi permukaan serang).
no-cli

# Logging secukupnya untuk troubleshooting awal.
verbose
log-file=/var/log/turnserver.log
