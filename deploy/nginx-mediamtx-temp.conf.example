# Config SEMENTARA — hanya port 80, tanpa SSL. Dipakai supaya certbot bisa
# verifikasi domain (langkah 2), lalu certbot OTOMATIS menambahkan bagian
# SSL-nya sendiri ke file ini (langkah 3) — tidak perlu edit manual lagi
# setelah itu. Proxy ke MediaMTX sudah aktif dari langkah ini juga.
server {
    listen 80;
    server_name media.GANTI-DOMAIN-FASOP;

    location / {
        proxy_pass http://127.0.0.1:8889;
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 30s;
        proxy_send_timeout 30s;
    }
}
